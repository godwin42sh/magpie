# Copy to .env and adjust. Consumed by docker-compose (backend service).

# --- Ports ---
# Host port the frontend (nginx) is published on. Open http://localhost:8080.
FRONTEND_PORT=8080
# Backend listen port inside its container (also published for direct access).
PORT=3000

# --- FlareSolverr ---
# Cloudflare-challenge solver. Inside compose the backend reaches it by its
# service name; leave this as-is unless you run FlareSolverr elsewhere.
FLARESOLVERR_URL=http://flaresolverr:8191

# --- Camoufox ---
# Anti-detect Firefox sidecar — last-resort fetch tier for bot protection
# (Akamai/DataDome/Cloudflare) that the above cannot beat. The backend escalates
# to it only when other strategies return an empty/blocked page. Leave empty to
# disable. Inside compose the backend reaches it by service name.
CAMOUFOX_URL=http://camoufox:8192

# --- Notifications ---
# Discord/Slack incoming webhook URL the backend POSTs to on a detected change.
# Leave empty to disable notifications.
NOTIFY_WEBHOOK_URL=

# --- Persistence (paths inside the backend container; volume-mounted) ---
CONFIG_PATH=/app/data/config.json
STATE_PATH=/app/data/state
